<idea-plugin>
    <id>org.mozilla.phabricator</id>
    <name>Mozilla Phabricator</name>
    <vendor email="jalmeida@mozilla.com" url="https://github.com/jonalmeida/phabricator-review-intellij">Mozilla</vendor>

    <description><![CDATA[
        Browse and review Mozilla Phabricator differential revisions inside JetBrains IDEs.<br/>
        <em>Port of the phabricator-review-vscode extension. Phase 1 ships read-only browsing.</em>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="org.mozilla.phabricator.service.PhabricatorSettings"/>
        <applicationService
            serviceImplementation="org.mozilla.phabricator.service.CredentialStore"/>
        <applicationService
            serviceImplementation="org.mozilla.phabricator.service.PhabSessionService"/>
        <applicationConfigurable
            id="org.mozilla.phabricator.settings"
            displayName="Mozilla Phabricator"
            parentId="tools"
            instance="org.mozilla.phabricator.ui.settings.PhabricatorConfigurable"/>
        <toolWindow
            id="Phabricator"
            anchor="right"
            icon="/icons/phabricator.svg"
            factoryClass="org.mozilla.phabricator.ui.toolwindow.PhabricatorToolWindowFactory"/>
        <notificationGroup
            id="Mozilla Phabricator"
            displayType="BALLOON"/>
        <projectService
            serviceImplementation="org.mozilla.phabricator.service.RevisionsManager"/>
        <diff.DiffExtension
            implementation="org.mozilla.phabricator.diff.PhabricatorDiffExtension"/>
    </extensions>

    <applicationListeners>
        <listener
            class="org.mozilla.phabricator.service.PhabricatorAppActivationListener"
            topic="com.intellij.openapi.application.ApplicationActivationListener"/>
    </applicationListeners>

    <actions>
        <action
            id="Phabricator.SignIn"
            class="org.mozilla.phabricator.actions.SignInAction"
            text="Sign In to Mozilla Phabricator"
            description="Sign in with a Conduit API token."/>
        <action
            id="Phabricator.SignOut"
            class="org.mozilla.phabricator.actions.SignOutAction"
            text="Sign Out of Mozilla Phabricator"
            description="Forget the stored Conduit API token."/>
        <action
            id="Phabricator.Refresh"
            class="org.mozilla.phabricator.actions.RefreshRevisionsAction"
            text="Refresh Revisions"
            description="Re-fetch revisions in all categories."/>
        <action
            id="Phabricator.PublishDrafts"
            class="org.mozilla.phabricator.actions.PublishDraftsAction"
            text="Publish Phabricator Drafts"
            description="Promote your pending draft inline comments on this revision to published.">
            <add-to-group group-id="Diff.ViewerToolbar" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
