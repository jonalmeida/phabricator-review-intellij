<idea-plugin>
    <id>com.mozilla.phabricator</id>
    <name>Mozilla Phabricator</name>
    <vendor email="jalmeida@mozilla.com" url="https://github.com/jonalmeida/phabricator-review-intellij">Mozilla</vendor>

    <description><![CDATA[
        Browse and review Mozilla Phabricator differential revisions inside JetBrains IDEs.<br/>
        <em>Port of the phabricator-review-vscode extension. Phase 1 ships read-only browsing.</em>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceImplementation="com.mozilla.phabricator.service.PhabricatorSettings"/>
        <applicationService
            serviceImplementation="com.mozilla.phabricator.service.CredentialStore"/>
        <applicationService
            serviceImplementation="com.mozilla.phabricator.service.PhabSessionService"/>
        <applicationConfigurable
            id="com.mozilla.phabricator.settings"
            displayName="Mozilla Phabricator"
            parentId="tools"
            instance="com.mozilla.phabricator.ui.settings.PhabricatorConfigurable"/>
    </extensions>

    <actions>
        <!-- Sign-in/out + refresh actions are added in later commits. -->
    </actions>
</idea-plugin>
